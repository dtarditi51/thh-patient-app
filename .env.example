# Google Places API (per-office reviews) and Maps Embed API (location detail maps).
# The same key works for both APIs; enable both in the Google Cloud Console and
# restrict by HTTP referrer to your production domain. Server-side only — no
# NEXT_PUBLIC_ prefix so it never ships in the client bundle.
GOOGLE_PLACES_API_KEY=

# Rater8 embed (per-provider widget IDs or API token)
RATER8_API_TOKEN=

# Firebase for push notifications
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_SERVER_KEY=

# Luma Health portal URL (passthrough)
NEXT_PUBLIC_PORTAL_URL=https://portal.hearthousenj.com

# Practice info
NEXT_PUBLIC_MAIN_PHONE=856-546-3003
NEXT_PUBLIC_MAIN_FAX=856-547-5337
