# Server-side Google API key — covers Places Details (per-office reviews) and
# Maps Embed (location detail iframe). Enable both APIs in the Google Cloud
# Console. Restrict by HTTP referrer to your production domain. No NEXT_PUBLIC_
# prefix so it stays out of the client bundle.
GOOGLE_PLACES_API_KEY=

# Client-side Google Maps JavaScript API key — used by the interactive
# locations map (@vis.gl/react-google-maps). Must be a DIFFERENT key from the
# server-side one above so each can be restricted independently. Enable the
# Maps JavaScript API and restrict by HTTP referrer to:
#   - https://app.hearthousenj.com/*
#   - https://*.vercel.app/* (or the specific Vercel preview pattern)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Map ID for custom map styling configured in the Google Cloud
# Console. Falls back to a default ID if not set.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Rater8 embed (per-provider widget IDs or API token)
RATER8_API_TOKEN=

# Firebase for push notifications
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_SERVER_KEY=

# Luma Health portal URL (passthrough)
NEXT_PUBLIC_PORTAL_URL=https://portal.hearthousenj.com

# Practice info
NEXT_PUBLIC_MAIN_PHONE=856-546-3003
NEXT_PUBLIC_MAIN_FAX=856-547-5337
